# ── Anthropic ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ───────────────────────────────────────
# Local dev (matches docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://studyowl:studyowl@localhost/studyowl

# ── Redis ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# ── Alerts ─────────────────────────────────────────
SENDGRID_API_KEY=SG....
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TEACHER_ALERT_EMAIL=teacher@yourschool.com

# ── OCR (optional — Tesseract used by default) ─────
GOOGLE_VISION_API_KEY=

# ── Object storage (Cloudflare R2) ─────────────────
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=studyowl-uploads
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
