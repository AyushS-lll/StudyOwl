# ── Azure OpenAI ──────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4

# ── Database ───────────────────────────────────────
# Local dev (matches docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://studyowl:studyowl@localhost/studyowl

# ── Redis ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# ── Alerts ─────────────────────────────────────────
SENDGRID_API_KEY=SG....
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TEACHER_ALERT_EMAIL=teacher@yourschool.com

# ── OCR (optional — Tesseract used by default) ─────
GOOGLE_VISION_API_KEY=

# ── Object storage (Cloudflare R2) ─────────────────
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=studyowl-uploads
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ── Travily learning resource API ────────────────
TRAVILY_API_KEY=
TRAVILY_API_URL=
