# ── Azure OpenAI ──────────────────────────────────
# AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://openai-agent-project.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini

# ── Database ───────────────────────────────────────
# Local dev (matches docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://studyowl:studyowl@localhost/studyowl

# ── Redis ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────
# Generate with: openssl rand -hex 32
# SECRET_KEY=

# ── Alerts ─────────────────────────────────────────
SENDGRID_API_KEY=SG....
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TEACHER_ALERT_EMAIL=teacher@yourschool.com

# ── OCR (optional — Tesseract used by default) ─────
GOOGLE_VISION_API_KEY=

# ── Object storage (Cloudflare R2) ─────────────────
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=studyowl-uploads
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

TRAVILY_API_URL=https://mcp.tavily.com/mcp/?tavilyApiKey=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